import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

/**
 * Demonstrates basic playlist management using arrays and ArrayLists.
 *
 * This program creates a list of favorite songs, prints selected songs,
 * builds a smaller "desert island" playlist, combines playlists, removes
 * extra songs, and demonstrates how to swap songs within an ArrayList.
 */
public class Playlist {

    /**
     * Entry point for the playlist demonstration program.
     *
     * @param args command-line arguments (not used)
     */
    public static void main(String[] args) {

        // Stores a fixed collection of favorite songs.
        String[] favoriteSongs = {
                "a", "b", "c", "d", "e",
                "f", "g", "h", "i", "j"
        };

        // Display the first three favorite songs.
        System.out.println(favoriteSongs[0]);
        System.out.println(favoriteSongs[1]);
        System.out.println(favoriteSongs[2]);

        // Create a smaller playlist of essential songs.
        List<String> desertIsland = new ArrayList<>();

        desertIsland.add("rek");
        desertIsland.add("dak");
        desertIsland.add("ren");
        desertIsland.add("mal");
        desertIsland.add("lea");

        // Add all favorite songs to the desert island playlist.
        desertIsland.addAll(Arrays.asList(favoriteSongs));

        System.out.println("Playlist size after adding favorite songs: " + desertIsland.size());

        // Remove the songs that were added from favoriteSongs.
        desertIsland.subList(5, desertIsland.size()).clear();

        System.out.println("Playlist size after trimming: " + desertIsland.size());
        System.out.println("Current playlist: " + desertIsland);

        // Find the positions of two songs to swap.
        int songAIndex = desertIsland.indexOf("rek");
        int songBIndex = desertIsland.indexOf("dak");

        // Swap the two songs if both exist in the playlist.
        if (songAIndex != -1 && songBIndex != -1) {
            String tempSong = desertIsland.get(songAIndex);

            desertIsland.set(songAIndex, desertIsland.get(songBIndex));
            desertIsland.set(songBIndex, tempSong);
        }

        System.out.println("Playlist after swap: " + desertIsland);
    }
}
