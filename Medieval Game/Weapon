/**
 * Represents a weapon used by the player.
 *
 * A Weapon has a name and a fixed damage value. Unlike armour,
 * weapons do not degrade over time in the current design.
 *
 * This class is immutable once created.
 */
public class Weapon {

    /** The name of the weapon (immutable). */
    private final String name;

    /** The base damage dealt by the weapon (immutable). */
    private final int damage;

    /**
     * Constructs a new Weapon object.
     *
     * @param name   the name of the weapon
     * @param damage the damage value of the weapon
     */
    public Weapon(String name, int damage) {
        this.name = name;
        this.damage = damage;
    }

    /**
     * @return the name of the weapon
     */
    public String getName() {
        return name;
    }

    /**
     * @return the damage value of the weapon
     */
    public int getDamage() {
        return damage;
    }

    /**
     * Returns a string representation of the weapon.
     *
     * @return formatted weapon information
     */
    @Override
    public String toString() {
        return name + " (Damage: " + damage + ")";
    }
}
