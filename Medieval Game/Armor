import java.io.Serializable;

/**
 * This class represents a piece of armour in the game.
 *
 * Armour has a name, durability, and a defense rating.
 * As durability goes down, the defense also becomes weaker.
 */
public class Armour implements Serializable {

    private static final long serialVersionUID = 1L;

    // Name of the armour (does not change)
    private final String name;

    // Current durability (0–100)
    private int durability;

    // Base defense value
    private int defenseRating;

    // Constructor to create a new piece of armour
    public Armour(String name, int durability, int defenseRating) {
        this.name = name;
        this.durability = durability;
        this.defenseRating = defenseRating;
    }

    // Reduces durability when the armour takes damage
    public void reduceDurability(int reduction) {
        durability -= reduction;

        // If durability drops to 0 or below, armour is broken
        if (durability <= 0) {
            durability = 0;
            defenseRating = 0;

            System.out.println("Your " + name + " is broken and useless now.");
        }
    }

    // Repairs the armour by increasing durability
    public void repairArmour(int amount) {

        // If it's already broken, do nothing
        if (durability == 0) {
            return;
        }

        durability += amount;

        // Cap durability at 100
        if (durability > 100) {
            durability = 100;
        }
    }

    // Returns the defense value based on current durability
    public int getDefenseRating() {
        return (int) (defenseRating * (durability / 100.0));
    }

    // Prints a simple description of the armour
    @Override
    public String toString() {
        return name + " (Defense: " + getDefenseRating() + ")";
    }
}
