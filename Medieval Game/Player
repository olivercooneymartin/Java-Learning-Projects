import java.io.Serializable;

/**
 * Represents the player character in the game.
 *
 * The Player class manages core player attributes such as health,
 * equipped weapon, and equipped armour. It also handles combat-related
 * calculations like damage taken and total defense rating.
 *
 * Implements Serializable to allow saving and loading player state.
 */
public class Player implements Serializable {

    private static final long serialVersionUID = 1L;

    /** The player's name (immutable after creation). */
    private final String name;

    /** The player's current health (0–100). */
    private double health;

    /** The weapon currently equipped by the player. */
    private Weapon currentWeapon;

    /** Equipped armour pieces (may be null if not equipped). */
    private Helmet helmet;
    private Shirt shirt;
    private Trouser trouser;
    private Shoe shoe;

    /**
     * Constructs a new Player with a default weapon and full health.
     *
     * @param name the player's name
     */
    public Player(String name) {
        this.name = name;
        this.currentWeapon = new Weapon("Rusty Short Sword", 3);
        this.health = 100;
    }

    /**
     * Applies incoming damage to the player after factoring in defense.
     *
     * @param enemyAttack the raw attack value from an enemy
     */
    public void takeDamage(double enemyAttack) {
        double damage = enemyAttack - (getDefenseRating() / 5.0);

        // Prevent negative damage (healing from attacks)
        if (damage < 0) {
            damage = 0;
        }

        this.health -= damage;

        if (this.health <= 0) {
            this.health = 0;
            System.out.println("You have succumbed to the enemy. Better luck next time.");
            System.exit(1);
        } else {
            System.out.println("Current Health: " + this.health);
        }
    }

    /**
     * Heals the player by a specified amount, capped at 100.
     *
     * @param healthToAdd the amount of health to restore
     */
    public void heal(double healthToAdd) {
        this.health += healthToAdd;

        if (this.health > 100) {
            this.health = 100;
        }
    }

    /**
     * @return the player's name
     */
    public String getName() {
        return name;
    }

    /**
     * Returns a formatted description of the currently equipped weapon.
     *
     * @return weapon description string
     */
    public String getCurrentWeapon() {
        return "Currently wielding: " +
                currentWeapon.getName() +
                ". This weapon does " +
                currentWeapon.getDamage() +
                " damage.\n";
    }

    /**
     * Sets the player's current weapon.
     *
     * @param currentWeapon the weapon to equip
     */
    public void setCurrentWeapon(Weapon currentWeapon) {
        this.currentWeapon = currentWeapon;
    }

    /**
     * @return the player's current health
     */
    public double getHealth() {
        return health;
    }

    /**
     * Calculates total defense rating from all equipped armour pieces.
     * Safely handles unequipped (null) armour.
     *
     * @return total defense rating
     */
    public int getDefenseRating() {
        int totalDefense = 0;

        if (helmet != null) {
            totalDefense += helmet.getDefenseRating();
        }
        if (shirt != null) {
            totalDefense += shirt.getDefenseRating();
        }
        if (trouser != null) {
            totalDefense += trouser.getDefenseRating();
        }
        if (shoe != null) {
            totalDefense += shoe.getDefenseRating();
        }

        return totalDefense;
    }

    public Helmet getHelmet() {
        return helmet;
    }

    public void setHelmet(Helmet helmet) {
        this.helmet = helmet;
    }

    public Shirt getShirt() {
        return shirt;
    }

    public void setShirt(Shirt shirt) {
        this.shirt = shirt;
    }

    public Trouser getTrouser() {
        return trouser;
    }

    public void setTrouser(Trouser trouser) {
        this.trouser = trouser;
    }

    public Shoe getShoe() {
        return shoe;
    }

    public void setShoe(Shoe shoe) {
        this.shoe = shoe;
    }

    /**
     * Returns a formatted summary of the player's current state.
     *
     * @return player information string
     */
    @Override
    public String toString() {
        return "\nCurrent Player:\n" +
                "Name: " + name + "\n" +
                "Health: " + getHealth() + "\n" +
                getCurrentWeapon() +
                "Equipped Armour:\n" +
                "   Helmet: " + (helmet != null ? helmet : "None") +
                "   Shirt: " + (shirt != null ? shirt : "None") +
                "   Trousers: " + (trouser != null ? trouser : "None") +
                "   Shoes: " + (shoe != null ? shoe : "None");
    }
}
