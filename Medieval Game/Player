import java.io.Serializable;

/**
 * This class represents the player in the game.
 *
 * The player has health, a weapon, and some armour.
 */
public class Player implements Serializable {

    private static final long serialVersionUID = 1L;

    // Player name
    private final String name;

    // Player health (starts at 100)
    private double health;

    // Current weapon
    private Weapon currentWeapon;

    // Armour pieces (can be null if not equipped)
    private Helmet helmet;
    private Shirt shirt;
    private Trouser trouser;
    private Shoe shoe;

    // Constructor
    public Player(String name) {
        this.name = name;
        this.currentWeapon = new Weapon("Rusty Short Sword", 3);
        this.health = 100;
    }

    // Called when the player takes damage
    public void takeDamage(double enemyAttack) {

        // Reduce damage based on defense
        double damage = enemyAttack - (getDefenseRating() / 5.0);

        // Make sure damage is not negative
        if (damage < 0) {
            damage = 0;
        }

        health -= damage;

        // Check if player is dead
        if (health <= 0) {
            health = 0;
            System.out.println("You died. Game over.");
            System.exit(1);
        } else {
            System.out.println("Health: " + health);
        }
    }

    // Heals the player
    public void heal(double amount) {
        health += amount;

        // Cap health at 100
        if (health > 100) {
            health = 100;
        }
    }

    // Returns player name
    public String getName() {
        return name;
    }

    // Returns info about the current weapon
    public String getCurrentWeapon() {
        return "Weapon: " +
                currentWeapon.getName() +
                " (Damage: " +
                currentWeapon.getDamage() + ")\n";
    }

    // Sets a new weapon
    public void setCurrentWeapon(Weapon weapon) {
        this.currentWeapon = weapon;
    }

    // Returns current health
    public double getHealth() {
        return health;
    }

    // Adds up defense from all armour pieces
    public int getDefenseRating() {

        int total = 0;

        if (helmet != null) {
            total += helmet.getDefenseRating();
        }
        if (shirt != null) {
            total += shirt.getDefenseRating();
        }
        if (trouser != null) {
            total += trouser.getDefenseRating();
        }
        if (shoe != null) {
            total += shoe.getDefenseRating();
        }

        return total;
    }

    // Getters and setters for armour
    public Helmet getHelmet() {
        return helmet;
    }

    public void setHelmet(Helmet helmet) {
        this.helmet = helmet;
    }

    public Shirt getShirt() {
        return shirt;
    }

    public void setShirt(Shirt shirt) {
        this.shirt = shirt;
    }

    public Trouser getTrouser() {
        return trouser;
    }

    public void setTrouser(Trouser trouser) {
        this.trouser = trouser;
    }

    public Shoe getShoe() {
        return shoe;
    }

    public void setShoe(Shoe shoe) {
        this.shoe = shoe;
    }

    // Prints player info
    @Override
    public String toString() {
        return "\nPlayer:\n" +
                "Name: " + name + "\n" +
                "Health: " + health + "\n" +
                getCurrentWeapon() +
                "Armour:\n" +
                "   Helmet: " + (helmet != null ? helmet : "None") +
                "   Shirt: " + (shirt != null ? shirt : "None") +
                "   Trousers: " + (trouser != null ? trouser : "None") +
                "   Shoes: " + (shoe != null ? shoe : "None");
    }
}
