/**
 * Represents a general language.
 *
 * Stores basic information like name, number of speakers,
 * regions where it is spoken, and its word order.
 */
public class Language {

    // Basic information about the language
    protected String name;
    protected int numSpeakers;
    protected String regionsSpoken;
    protected String wordOrder;

    /**
     * Constructor to create a Language object.
     */
    public Language(String langName, int speakers, String regions, String wOrder) {
        this.name = langName;
        this.numSpeakers = speakers;
        this.regionsSpoken = regions;
        this.wordOrder = wOrder;
    }

    /**
     * Prints information about the language.
     */
    public void getInfo() {
        System.out.println(
            this.name + " is spoken by " +
            this.numSpeakers +
            " people mainly in " +
            this.regionsSpoken +
            ". The language follows the word order: " +
            this.wordOrder + "."
        );
    }

    public static void main(String[] args) {

        // Basic Language object
        Language harkonnen = new Language(
            "Harkonnen",
            10000000,
            "Geidi Prime",
            "subject-verb-object"
        );
        harkonnen.getInfo();

        // Subclass examples
        Language quetzel = new Mayan("Quetzel", 50000);
        quetzel.getInfo();

        Language chinese = new SinoTibetan("Chinese", 100);
        chinese.getInfo();
    }
}
