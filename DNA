/**
 * A simple DNA analysis program.
 *
 * This program searches a DNA sequence for a valid protein-coding region.
 * A valid protein is defined as:
 * - Starting with the start codon "ATG"
 * - Ending with the stop codon "TGA"
 * - Having a length between start and stop that is a multiple of 3
 *
 * If a valid protein is found, it is extracted and printed.
 */
public class DNA {

    /**
     * Extracts a protein sequence from a DNA string if valid conditions are met.
     *
     * @param dna the DNA sequence to analyze
     * @return the protein sequence, or null if no valid protein is found
     */
    public static String findProtein(String dna) {
        int start = dna.indexOf("ATG");
        int stop = dna.indexOf("TGA");

        // Validate that both codons exist and are in a correct reading frame
        if (start != -1 && stop != -1 && (stop - start) % 3 == 0) {
            return dna.substring(start, stop);
        }

        return null;
    }

    /**
     * Entry point for the DNA analysis program.
     *
     * @param args command-line arguments (not used)
     */
    public static void main(String[] args) {

        // Example DNA sequences
        String dna1 = "ATGCGATACGCTTGA";
        String dna2 = "ATGCGATACGTGA";
        String dna3 = "ATTAATATGTACTGA";

        // Select which DNA sequence to analyze
        String dna = dna1;

        // Output basic information
        System.out.println("DNA Length: " + dna.length());

        // Attempt to find a protein
        String protein = findProtein(dna);

        if (protein != null) {
            System.out.println("Protein: " + protein);
        } else {
            System.out.println("No valid protein found.");
        }
    }
}
