/**
 * Simple calculator program.
 *
 * This class has basic math functions like add, subtract,
 * multiply, divide, and modulo.
 */
public class Calculator {

    // Adds two numbers together
    public int add(int a, int b) {
        return a + b;
    }

    // Subtracts b from a
    public int subtract(int a, int b) {
        return a - b;
    }

    // Multiplies two numbers
    public int multiply(int a, int b) {
        return a * b;
    }

    // Divides a by b
    public int divide(int a, int b) {

        // Check to make sure we are not dividing by 0
        if (b == 0) {
            System.out.println("Cannot divide by zero!");
            return 0;
        }

        return a / b;
    }

    // Finds the remainder when a is divided by b
    public int modulo(int a, int b) {

        // Check to make sure we are not dividing by 0
        if (b == 0) {
            System.out.println("Cannot use modulo with zero!");
            return 0;
        }

        return a % b;
    }

    public static void main(String[] args) {

        // Create a calculator object
        Calculator calc = new Calculator();

        // Test the methods
        System.out.println("Add: " + calc.add(5, 7));
        System.out.println("Subtract: " + calc.subtract(45, 11));
        System.out.println("Multiply: " + calc.multiply(3, 4));
        System.out.println("Divide: " + calc.divide(20, 5));
        System.out.println("Modulo: " + calc.modulo(10, 3));
    }
}
