import java.awt.Color;
import java.awt.image.BufferedImage;
import java.io.File;
import java.net.URL;
import java.util.Arrays;
import java.util.Random;
import javax.imageio.ImageIO;

/**
 * Simple image processing program.
 *
 * This program loads an image into a 2D array and performs
 * different transformations such as trimming, inverting colors,
 * stretching, and drawing shapes.
 */
public class Solution {

    public static void main(String[] args) {

        // Load image into a 2D array
        int[][] imageData = imgToTwoD("./apple.jpg");

        // Trim borders
        int[][] trimmed = trimBorders(imageData, 60);
        twoDToImage(trimmed, "./trimmed_apple.jpg");

        // Create negative image
        int[][] negative = negativeColor(imageData);
        twoDToImage(negative, "./negative_apple.jpg");

        // Stretch horizontally
        int[][] stretchedHImg = stretchHorizontally(imageData);
        twoDToImage(stretchedHImg, "./stretched_apple.jpg");

        // Shrink vertically
        int[][] shrankVImg = shrinkVertically(imageData);
        twoDToImage(shrankVImg, "./shrank_apple.jpg");

        // Invert image (flip)
        int[][] invertedImg = invertImage(imageData);
        twoDToImage(invertedImg, "./inverted_apple.jpg");

        // Apply color filter
        int[][] coloredImg = colorFilter(imageData, -75, 30, -30);
        twoDToImage(coloredImg, "./colored_apple.jpg");

        // Create random image
        int[][] blankImg = new int[500][500];
        int[][] randomImg = paintRandomImage(blankImg);
        twoDToImage(randomImg, "./random_img.jpg");

        // Draw rectangle
        int[] rgba = {255, 255, 0, 255};
        int color = getColorIntValFromRGBA(rgba);

        int[][] rectangleImg = paintRectangle(randomImg, 200, 200, 100, 100, color);
        twoDToImage(rectangleImg, "./rectangle.jpg");

        // Generate multiple random rectangles
        int[][] generatedRectangles = generateRectangles(randomImg, 1000);
        twoDToImage(generatedRectangles, "./generated_rect.jpg");
    }

    /**
     * Removes a border of pixels from all sides of the image.
     */
    public static int[][] trimBorders(int[][] imageTwoD, int pixelCount) {

        // Make sure we are not trimming too much
        if (imageTwoD.length > pixelCount * 2 && imageTwoD[0].length > pixelCount * 2) {

            int[][] trimmedImg = new int[
                    imageTwoD.length - pixelCount * 2
            ][
                    imageTwoD[0].length - pixelCount * 2
            ];

            for (int i = 0; i < trimmedImg.length; i++) {
                for (int j = 0; j < trimmedImg[i].length; j++) {

                    // Shift pixels inward by pixelCount
                    trimmedImg[i][j] = imageTwoD[i + pixelCount][j + pixelCount];
                }
            }

            return trimmedImg;

        } else {
            System.out.println("Cannot trim that many pixels.");
            return imageTwoD;
        }
    }

    /**
     * Creates a negative version of the image.
     */
    public static int[][] negativeColor(int[][] imageTwoD) {

        int[][] result = new int[imageTwoD.length][imageTwoD[0].length];

        for (int i = 0; i < imageTwoD.length; i++) {
            for (int j = 0; j < imageTwoD[i].length; j++) {

                int[] rgba = getRGBAFromPixel(imageTwoD[i][j]);

                // Invert each color channel
                rgba[0] = 255 - rgba[0]; // Red
                rgba[1] = 255 - rgba[1]; // Green
                rgba[2] = 255 - rgba[2]; // Blue

                result[i][j] = getColorIntValFromRGBA(rgba);
            }
        }

        return result;
    }

    /**
     * Doubles the width of the image by duplicating pixels horizontally.
     */
    public static int[][] stretchHorizontally(int[][] imageTwoD) {

        int[][] result = new int[imageTwoD.length][imageTwoD[0].length * 2];

        for (int i = 0; i < imageTwoD.length; i++) {
            for (int j = 0; j < imageTwoD[i].length; j++) {

                int index = j * 2;

                // Copy each pixel twice
                result[i][index] = imageTwoD[i][j];
                result[i][index + 1] = imageTwoD[i][j];
            }
        }

        return result;
    }
}
