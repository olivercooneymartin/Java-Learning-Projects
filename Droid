/**
 * Simple program that represents a Droid.
 *
 * A Droid has a name and a battery level.
 * It can perform tasks, which reduces its battery,
 * and report its current energy level.
 */
public class Droid {

    // The droid's current battery level (0–100)
    int batteryLevel;

    // The droid's name
    String name;

    /**
     * Creates a new Droid with a given name.
     * Battery starts at 100.
     */
    public Droid(String droidName) {
        name = droidName;
        batteryLevel = 100;
    }

    /**
     * Returns a simple description of the droid.
     */
    @Override
    public String toString() {
        return "This is the droid: " + name;
    }

    /**
     * Makes the droid perform a task.
     * Each task reduces battery by 10.
     */
    public void performTask(String task) {
        System.out.println(name + " is performing task: " + task);
        batteryLevel -= 10;
    }

    /**
     * Prints the current battery level.
     */
    public void energyReport() {
        System.out.println(name + " has " + batteryLevel + " battery remaining.");
    }

    /**
     * Main method to test the Droid class.
     */
    public static void main(String[] args) {
        Droid newDroid = new Droid("Codey");

        System.out.println(newDroid.name);
        System.out.println(newDroid);

        newDroid.performTask("Coding");
        newDroid.energyReport();
    }
}
