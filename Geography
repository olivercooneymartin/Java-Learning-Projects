/**
 * Simple program that prints a major city based on a continent number.
 *
 * Each number (1–7) corresponds to a continent.
 * Uses a switch statement to match the number and print a result.
 */
public class Continents {

    public static void main(String[] args) {

        // Change this number to test different continents
        int continent = 4;

        // Determine which continent was selected
        switch (continent) {

            case 1:
                System.out.println("North America: Mexico City, Mexico");
                break;

            case 2:
                System.out.println("South America: Sao Paulo, Brazil");
                break;

            case 3:
                System.out.println("Europe: Moscow, Russia");
                break;

            case 4:
                System.out.println("Africa: Lagos, Nigeria");
                break;

            case 5:
                System.out.println("Asia: Shanghai, China");
                break;

            case 6:
                System.out.println("Australia: Sydney, Australia");
                break;

            case 7:
                System.out.println("Antarctica: McMurdo Station, US");
                break;

            default:
                // Runs if the number doesn't match any continent
                System.out.println("Undefined continent!");
                break;
        }
    }
}
